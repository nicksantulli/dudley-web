---
// Visible FAQ — intentionally NOT mirrored by FAQPage JSON-LD. Google restricts FAQ
// rich results to authoritative gov/health sources, so we render the Q&A for readers
// and AI answer engines (good for AEO) but deliberately emit no FAQPage markup.
export interface Props {
  items: { q: string; a: string }[];
  heading?: string;
}
const { items, heading = 'Frequently asked questions' } = Astro.props;
---
{items && items.length > 0 && (
  <section aria-labelledby="faq-heading">
    <h2 id="faq-heading">{heading}</h2>
    <div class="faq">
      {items.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>
)}
