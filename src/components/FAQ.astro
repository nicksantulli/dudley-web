---
// Visible FAQ for readers and AI answer engines (good for AEO). The matching FAQPage
// JSON-LD is emitted by AppLanding.astro (built from the same app.faq) so the machine-
// readable Q&A stays in sync with what's rendered here. This component owns the visible
// markup only; it does not emit structured data itself.
export interface Props {
  items: { q: string; a: string }[];
  heading?: string;
}
const { items, heading = 'Frequently asked questions' } = Astro.props;
---
{items && items.length > 0 && (
  <section aria-labelledby="faq-heading">
    <h2 id="faq-heading">{heading}</h2>
    <div class="faq">
      {items.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>
)}
