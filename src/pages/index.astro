---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { rel, abs, ORIGIN, appStoreUrl } from '../consts';

const allApps = (await getCollection('apps')).sort((a, b) => a.data.order - b.data.order);
// Studio's own apps vs. client work (apps built for a partner — see `developedFor`).
const apps = allApps.filter((a) => !a.data.developedFor);
const clientApps = allApps.filter((a) => a.data.developedFor);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dudley Development',
  url: ORIGIN,
};
const description =
  'Dudley Development is a small independent studio building polished, playful iPhone apps. Maker of Monetary Policy: Independence Day and Vibe Rater.';
---
<Base title="Dudley Development — iOS apps with character" description={description} path="/" schema={schema}>
  <main>
    <section class="hero">
      <div class="wrap">
        <span class="eyebrow">Independent iOS Studio</span>
        <h1>Small apps with<br /><span class="grad">real character.</span></h1>
        <p class="lede">
          Dudley Development is a studio building polished, playful iPhone apps —
          the kind you actually want to open. Free to play, privacy-first, and made with care.
        </p>
        <a class="btn primary" href="#apps">See the apps →</a>
      </div>
    </section>

    <section id="apps">
      <div class="wrap">
        <div class="section-head">
          <h2>The apps</h2>
          <p class="sub">Free on the App Store. No accounts. No nonsense.</p>
        </div>

        <ul class="app-list">
          {apps.map((app) => {
            const url = appStoreUrl(app.data.appStoreId);
            const live = app.data.status === 'live' && !!url;
            const hasPage = app.data.landingPage !== false;
            const slug = app.slug;
            return (
              <li class="app-row">
                <img class="icon" src={rel(app.data.icon)} alt={`${app.data.name} app icon`} width="64" height="64" loading="lazy" />
                <div class="row-main">
                  <div class="row-head">
                    <h3>{app.data.name}</h3>
                    <span class={`badge ${live ? 'live' : 'soon'}`}>
                      <span class="dot"></span> {live ? 'Live' : 'Coming soon'}
                    </span>
                  </div>
                  <p class="tagline" title={app.data.tagline}>{app.data.tagline}</p>
                  <p class="desc">{app.data.description}</p>
                </div>
                <div class="actions">
                  {live && <a class="btn primary" href={url} rel="noopener">Download</a>}
                  {hasPage && <a class={`btn${live ? '' : ' primary'}`} href={rel(`/apps/${slug}/`)}>Learn more</a>}
                  {hasPage && <a class="btn ghost" href={rel(`/privacy/${slug}`)}>Privacy</a>}
                  {!live && !hasPage && <span class="btn ghost disabled" aria-disabled="true">Coming soon</span>}
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    {clientApps.length > 0 && (
      <section id="client-work">
        <div class="wrap">
          <div class="section-head">
            <h2>Client work</h2>
            <p class="sub">Apps we design and build for partners, under their brand.</p>
          </div>

          <ul class="app-list">
            {clientApps.map((app) => {
              const url = appStoreUrl(app.data.appStoreId);
              const live = app.data.status === 'live' && !!url;
              const hasPage = app.data.landingPage !== false;
              const slug = app.slug;
              return (
                <li class="app-row">
                  <img class="icon" src={rel(app.data.icon)} alt={`${app.data.name} app icon`} width="64" height="64" loading="lazy" />
                  <div class="row-main">
                    <div class="row-head">
                      <h3>{app.data.name}</h3>
                      <span class="partner-tag">Created for {app.data.developedFor}</span>
                      <span class={`badge ${live ? 'live' : 'soon'}`}>
                        <span class="dot"></span> {live ? 'Live' : 'Coming soon'}
                      </span>
                    </div>
                    <p class="tagline" title={app.data.tagline}>{app.data.tagline}</p>
                    <p class="desc">{app.data.description}</p>
                  </div>
                  <div class="actions">
                    {live && <a class="btn primary" href={url} rel="noopener">Download</a>}
                    {hasPage && <a class={`btn${live ? '' : ' primary'}`} href={rel(`/apps/${slug}/`)}>Learn more</a>}
                    {hasPage && <a class="btn ghost" href={rel(`/privacy/${slug}`)}>Privacy</a>}
                    {!live && !hasPage && <span class="btn ghost disabled" aria-disabled="true">Coming soon</span>}
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )}

    <section style="padding-top:8px;">
      <div class="wrap">
        <div class="app-card" style="text-align:center; align-items:center;">
          <h3 style="font-size:24px;">Built honestly, shipped carefully.</h3>
          <p class="desc" style="max-width:560px; margin:0 auto;">
            Every Dudley app is free, runs without an account, and keeps your data on your device.
            Ads are clearly disclosed and you can always opt out of tracking. That's the whole deal.
          </p>
          <div class="actions" style="justify-content:center;">
            <a class="btn" href={rel('/about')}>More about the studio →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
