---
import Base from './Base.astro';
import FAQ from '../components/FAQ.astro';
import InternalLinks from '../components/InternalLinks.astro';
import AppCTA from '../components/AppCTA.astro';
import { STUDIO, ORIGIN, rel, abs, APP_STORE } from '../consts';

export interface Props {
  archetype: any;
  related: { title: string; url: string; description: string }[];
  dateAdded: string;
}
const { archetype, related, dateAdded } = Astro.props;
const path = `/archetypes/${archetype.slug}/`;

const articleSchema = {
  '@type': 'Article',
  headline: `What Is ${archetype.name}? Meaning, Signs, and How Vibe Rater Scores It`,
  description: archetype.description,
  url: abs(path),
  datePublished: dateAdded,
  dateModified: dateAdded,
  author: { '@type': 'Organization', name: STUDIO, url: ORIGIN },
  publisher: {
    '@type': 'Organization',
    name: STUDIO,
    logo: { '@type': 'ImageObject', url: abs('/assets/dudley-mark.svg') },
  },
  about: { '@type': 'Thing', name: archetype.name },
};
// No FAQPage markup (Google restricts FAQ rich results); the visible FAQ stays.
const schema = { '@context': 'https://schema.org', ...articleSchema };
---
<Base title={`What Is ${archetype.name}? Meaning & Signs`} description={archetype.description} path={path} schema={schema} breadcrumbLeaf={archetype.name}>
  <main class="page">
    <div class="wrap" style="max-width:720px;">
      <nav class="crumbs">
        <a href={rel('/')}>Home</a><span class="sep">/</span>
        <a href={rel('/apps/vibe-rater/')}>Vibe Rater</a><span class="sep">/</span>
        <span>{archetype.name}</span>
      </nav>

      <div class="lede-hero">
        <span class="emoji" aria-hidden="true">{archetype.emoji}</span>
        <div>
          <h1>{archetype.name}</h1>
          <p class="updated">{archetype.tagline}</p>
        </div>
      </div>

      <slot />

      <AppCTA
        appName="Vibe Rater"
        appStoreId={APP_STORE.vibeRater}
        status={APP_STORE.vibeRater ? 'live' : 'coming_soon'}
        blurb={`See if you have ${archetype.name} — Vibe Rater rates your vibe from a photo and assigns your archetype.`}
      />

      <FAQ items={archetype.faq} />
      <InternalLinks pages={related} heading="Related archetypes" />
    </div>
  </main>
</Base>
