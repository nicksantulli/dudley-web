---
import { STUDIO, SUPPORT_EMAIL, SOCIAL_LINKS, SOCIALS, ORIGIN, rel, abs } from '../consts';

export interface Props {
  title: string;
  description: string;
  path: string;            // site-relative path, e.g. "/apps/powell-prowl/"
  ogImage?: string;        // site-relative or absolute
  schema?: object | null;  // page-specific JSON-LD
  noindex?: boolean;
}

const { title, description, path, ogImage = '/assets/dudley-lockup.png', schema = null, noindex = false } = Astro.props;
const canonical = abs(path);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : abs(ogImage);
const fullTitle = title.includes(STUDIO) ? title : `${title} | ${STUDIO}`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: STUDIO,
  url: ORIGIN,
  logo: { '@type': 'ImageObject', url: abs('/assets/dudley-mark.png') },
  contactPoint: { '@type': 'ContactPoint', email: SUPPORT_EMAIL, contactType: 'customer support' },
  sameAs: SOCIAL_LINKS,
};

const nav = [
  { href: rel('/#apps'), label: 'Apps' },
  { href: rel('/blog/'), label: 'Blog' },
  { href: rel('/about'), label: 'About' },
  { href: rel('/support'), label: 'Support' },
  { href: rel('/privacy/'), label: 'Privacy' },
];
const year = new Date().getFullYear();

// Monochrome platform glyphs (Simple Icons paths, 24×24, fill=currentColor so
// CSS tints them to the brand browns). Keyed by `icon` in SOCIALS.
const SOCIAL_ICONS: Record<string, string> = {
  x: 'M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z',
  instagram: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163C8.741 0 8.332.014 7.052.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z',
  tiktok: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex" />}
  <meta name="theme-color" content="#1C0D06" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#F2E8D5" media="(prefers-color-scheme: light)" />
  <link rel="icon" type="image/svg+xml" href={rel('/assets/dudley-mark.svg')} />
  <link rel="stylesheet" href={rel('/assets/style.css')} />
  <link rel="sitemap" href={rel('/sitemap-index.xml')} />
  <link rel="alternate" type="application/rss+xml" title="The Dudley Blog" href={rel('/blog/rss.xml')} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content={STUDIO} />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
  <header class="site">
    <div class="wrap">
      <a class="brand" href={rel('/')}>
        <img class="mark" src={rel('/assets/dudley-mark.png')} alt="" />
        Dudley Development
      </a>
      <nav class="top">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site">
    <div class="wrap">
      <div class="copy">© {year} {STUDIO}</div>
      <nav>
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      {SOCIALS.length > 0 && (
        <nav class="socials" aria-label="Follow Dudley Development on social media">
          {SOCIALS.map((s) => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} title={s.name}>
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
                <path d={SOCIAL_ICONS[s.icon]} />
              </svg>
            </a>
          ))}
        </nav>
      )}
    </div>
  </footer>
</body>
</html>
